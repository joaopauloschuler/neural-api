    object pgcWizard: TPageControl
      Left = 0
      Height = 430
      Top = 0
      Width = 540
      ActivePage = tsWelcome
      Align = alClient
      ShowTabs = False
      TabOrder = 0
      object tsWelcome: TTabSheet
        Caption = 'tsWelcome'
        ClientHeight = 422
        ClientWidth = 532
        object lblWelcome: TLabel
          Left = 20
          Height = 25
          Top = 20
          Width = 490
          Anchors = [akTop, akLeft, akRight]
          AutoSize = False
          Caption = 'Bem-vindo ao CAI Neural API'
          Font.Height = -19
          Font.Style = [fsBold]
          ParentColor = False
        end
        object lblWelcomeDesc: TLabel
          Left = 20
          Height = 40
          Top = 55
          Width = 490
          Anchors = [akTop, akLeft, akRight]
          AutoSize = False
          Caption = 'Este assistente irá guiar você através da instalação, download de modelos e configuração de teste do CAI Neural API.'
          WordWrap = True
          ParentColor = False
        end
        object lblLanguage: TLabel
          Left = 20
          Height = 15
          Top = 100
          Width = 120
          Caption = 'Language / Idioma:'
          ParentColor = False
        end
        object cmbLanguage: TComboBox
          Left = 150
          Height = 23
          Top = 97
          Width = 180
          Style = csDropDownList
          ItemHeight = 15
          ItemIndex = 1
          Items.Strings = (
            'English'
            'Português'
            'Français'
            'Deutsch'
            'Español'
            'العربية'
            '中文'
            '日本語'
            'Русский'
          )
          TabOrder = 1
          Text = 'Português'
          OnChange = cmbLanguageChange
        end
        object memWelcomeInfo: TMemo
          Left = 20
          Height = 260
          Top = 140
          Width = 490
          Anchors = [akTop, akLeft, akRight, akBottom]
          Lines.Strings = (
            'O CAI NEURAL API é uma biblioteca Pascal robusta para redes neurais, otimizada para instruções AVX e OpenCL (GPU).'
            ''
            'Destaques:'
            '- Execute LLMs reais de forma nativa e rápida (sem Python ou CUDA).'
            '- Suporte embutido para Transformers, MoE, RWKV e xLSTM.'
            '- Executável nativo único e otimizado.'
            ''
            'Clique em Avançar para prosseguir com a configuração.'
          )
          ReadOnly = True
          ScrollBars = ssAutoVertical
          TabOrder = 0
        end
      end
