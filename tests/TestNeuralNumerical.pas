procedure TTestNeuralNumerical.TestMaxBlurPoolGradientCheck;
begin
  // TNNetMaxBlurPool: anti-aliased maxpool (dense stride-1 max -> fixed
  // binomial blur -> subsample by stride). The blur weights are constant (no
  // gradient flows to them); Backpropagate must still route the input gradient
  // correctly through both the fixed blur (a transposed conv) and the max
  // selection (each blur tap routed to its dense-max argmax cell). The
  // Sin-seeded inputs give strictly distinct values on this tiny 4x4x2 shape so
  // every dense-max window has an unambiguous argmax and central differences
  // match the analytic input gradient.
  RandSeed := 424242;
  LayerInputGradientCheck(Self, TNNetMaxBlurPool.Create(2),
    'MaxBlurPool', 4, 4, 2, 0.01);
end;

