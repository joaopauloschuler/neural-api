            ' Y=' + IntToStr(Y), NN.GetLastLayer.Output[X, Y, 0] < -1e8)
        else
          AssertEquals('Offset band untouched at X=' + IntToStr(X) +
            ' Y=' + IntToStr(Y), 1.0, NN.GetLastLayer.Output[X, Y, 0], 0.0001);
      end;
