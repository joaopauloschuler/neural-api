      Input.Raw[i] := Sin(i * 0.4) * 1.5 + 0.1;
    for i := 0 to Desired.Size - 1 do
      Desired.Raw[i] := Cos(i * 0.3);

    LSwish.Neurons[0].Weights.Raw[0] := LSwish.Neurons[0].Weights.Raw[0] + epsilon;
