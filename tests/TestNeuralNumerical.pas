        NN2.GetLastLayer is TNNetProductKeyMemory);
      Saved2 := NN2.SaveToString();
      AssertEquals('AddProductKeyMemory SaveToString round-trip equality',
        Saved, Saved2);
    finally
      NN2.Free;
    end;
  finally
    NN.Free; Input.Free; Desired.Free;
  end;
