    AssertEquals('Hyena out SizeY', 1, NN.GetLastLayer.Output.SizeY);
    AssertEquals('Hyena out Depth', d_model, NN.GetLastLayer.Output.Depth);

    for i := 0 to Input.Size - 1 do
      Input.Raw[i] := Sin(i * 0.53) * 0.9 + 0.1;
