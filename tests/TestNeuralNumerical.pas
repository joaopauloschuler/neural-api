  NN: TNNet;
  Input, Target: TNNetVolume;
  LMid: TNNetIdentity;
  Vals: array[0..5] of TNeuralFloat;
  Eps, Expected: TNeuralFloat;
  i, CaseIdx: integer;
begin
  Vals[0] :=  0.0;
  Vals[1] :=  0.1;
  Vals[2] := -0.1;
  Vals[3] :=  1.0;
  Vals[4] := -1.0;
