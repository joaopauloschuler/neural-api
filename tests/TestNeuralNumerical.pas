    AssertEquals('Snake(0, alpha=1)',
      0.0, NN.GetLastLayer.Output.Raw[0], 1e-5);
    AssertEquals('Snake(pi/2, alpha=1)',
      HALF_PI + 1.0, NN.GetLastLayer.Output.Raw[1], 1e-5);
  finally
    NN.Free;
    Input.Free;
  end;
end;

