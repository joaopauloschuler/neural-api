    for oq := 0 to OutQ - 1 do
      for i := 0 to InSize - 1 do
        QL.Neurons[oq].Weights.Raw[i] := 0.13 * (i + 1) - 0.3 + 0.1 * oq;
    for i := 0 to OutSize - 1 do
      QL.Neurons[OutQ].Weights.Raw[i] := 0.04 - 0.02 * i;

    NN.Compute(Input);
