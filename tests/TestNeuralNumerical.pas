  NN: TNNet;
  Input: TNNetVolume;
  X, Y: integer;
begin
  // Offset=1 keeps a wider band: mask only where X > Y + 1.
  NN := TNNet.Create();
  Input := TNNetVolume.Create(4, 4, 1);
