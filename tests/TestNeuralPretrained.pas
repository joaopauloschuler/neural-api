  // Config-driven route: BuildFromPretrained must dispatch model_type
  // "nemotron_h" (architectures ["NemotronHForCausalLM"]) onto the same path.
  NN := BuildFromPretrained(FixturePath('tiny_nemotronh.safetensors'),
