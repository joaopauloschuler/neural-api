// Verifies the Whisper import target - the FIRST SPEECH model parity test:
// tests/fixtures/tiny_whisper.* is a pico randomly-initialized HF
// WhisperForConditionalGeneration (2+2 layers, 2 heads, d_model 12, the
// FULL 80 mel bins, vocab 31, max_source_positions 13 so the 26-frame mel
// input is HALVED by the stride-2 conv, PRE-norm + final stack norms,
// exact erf GELU, bias-free k_proj, learned decoder positions, sinusoidal
// encoder positions DROPPED from the checkpoint and regenerated by the
// importer, tied head). The generator tools/whisper_tiny_fixture.py
// asserts every quirk moves the float64 oracle above the 1e-4 gate -
// including that the tanh-GELU approximation would FAIL this test. The
// parity loop feeds the pinned float mel volume (dyadic values: exact in
// f32 and JSON) through the encoder, compares the final hidden states,
// then runs the pair RunT5-style and compares the decoder logits.
// Non-vacuity shape checks: the encoder input is (26,1,80) while its
// output grid is 13 tokens - the cross-attention really is RECTANGULAR
// (13 encoder positions vs 6 decoder positions).
procedure TTestNeuralPretrained.TestWhisperParity;
var
  Enc, Dec: TNNet;
  Config: TWhisperConfig;
  RefRoot: TJSONData;
  MelInputs, DecSeqs, EncHidden, LogitsArr: TJSONArray;
  MelArr, RowArr, SeqArr, PosArr: TJSONArray;
  EncInput, DecInput, Logits: TNNetVolume;
  RefJson: TStringList;
  SeqCnt, FrameCnt, MelCnt, PosCnt, ChCnt: integer;
  Diff, MaxHiddenDiff, MaxLogitDiff: double;
const
  DecLen = 6;
begin
  RandSeed := 424242;
  BuildWhisperFromSafeTensors(FixturePath('tiny_whisper.safetensors'),
    Enc, Dec, Config, {DecSeqLen=}DecLen, {pInferenceOnly=}false,
    FixturePath('tiny_whisper_config.json'));
  RefJson := TStringList.Create;
  EncInput := TNNetVolume.Create;
  DecInput := TNNetVolume.Create;
  Logits := TNNetVolume.Create;
  RefRoot := nil;
  try
    AssertTrue('encoder built', Enc <> nil);
    AssertTrue('decoder built', Dec <> nil);
    // The mel input grid is TWICE the encoder output grid (stride-2 conv).
    AssertEquals('encoder mel input frames', 2 * Config.MaxSourcePositions,
      Enc.Layers[0].Output.SizeX);
    AssertEquals('encoder mel input depth', Config.NumMelBins,
      Enc.Layers[0].Output.Depth);
    AssertEquals('encoder output halved by the stride-2 conv',
      Config.MaxSourcePositions * Config.DModel,
      Enc.GetLastLayer().Output.Size);
    // The decoder must expose its second (encoder-states) input - the
    // convention shared with the T5/Marian importers, so RunT5 runs the
    // pair; its 13-token grid differs from the 6-token decoder grid
    // (rectangular cross-attention).
    AssertTrue('decoder second input is TNNetInput',
      T5EncoderStatesInput(Dec) is TNNetInput);
    AssertEquals('encoder-states input size',
      Config.MaxSourcePositions * Config.DModel,
      T5EncoderStatesInput(Dec).Output.Size);
    AssertEquals('decoder token input length', DecLen,
      Dec.Layers[0].Output.SizeX);

    RefJson.LoadFromFile(FixturePath('tiny_whisper_logits.json'));
    RefRoot := GetJSON(RefJson.Text);
    MelInputs := TJSONArray(TJSONObject(RefRoot).Find('mel_inputs'));
    DecSeqs := TJSONArray(TJSONObject(RefRoot).Find('dec_sequences'));
    EncHidden := TJSONArray(TJSONObject(RefRoot).Find('enc_hidden'));
    LogitsArr := TJSONArray(TJSONObject(RefRoot).Find('logits'));
    AssertTrue('mel_inputs present', MelInputs <> nil);
    AssertTrue('dec_sequences present', DecSeqs <> nil);
    AssertTrue('enc_hidden present', EncHidden <> nil);
    AssertTrue('logits present', LogitsArr <> nil);
    AssertTrue('at least 2 sequences', MelInputs.Count >= 2);
    AssertEquals('row counts match', MelInputs.Count, DecSeqs.Count);
    MaxHiddenDiff := 0;
    MaxLogitDiff := 0;
    EncInput.ReSize(2 * Config.MaxSourcePositions, 1, Config.NumMelBins);
    DecInput.ReSize(DecLen, 1, 1);
    for SeqCnt := 0 to MelInputs.Count - 1 do
    begin
      // The fixture stores the HF (num_mel_bins, frames) layout; the
      // encoder input volume is (frames, 1, num_mel_bins).
      MelArr := TJSONArray(MelInputs.Items[SeqCnt]);
      AssertEquals('mel bins', Config.NumMelBins, MelArr.Count);
      for MelCnt := 0 to Config.NumMelBins - 1 do
      begin
        RowArr := TJSONArray(MelArr.Items[MelCnt]);
        AssertEquals('mel frames', 2 * Config.MaxSourcePositions,
          RowArr.Count);
        for FrameCnt := 0 to RowArr.Count - 1 do
          EncInput.FData[FrameCnt * Config.NumMelBins + MelCnt] :=
            RowArr.Items[FrameCnt].AsFloat;
      end;
      SeqArr := TJSONArray(DecSeqs.Items[SeqCnt]);
      AssertEquals('dec sequence length', DecLen, SeqArr.Count);
      for PosCnt := 0 to DecLen - 1 do
        DecInput.FData[PosCnt] := SeqArr.Items[PosCnt].AsInteger;
      // Encoder-only parity: final hidden states vs HF
      // encoder.last_hidden_state (float64 oracle).
      Enc.Compute(EncInput);
      PosArr := TJSONArray(EncHidden.Items[SeqCnt]);
      AssertEquals('enc hidden rows', Config.MaxSourcePositions,
        PosArr.Count);
      for PosCnt := 0 to Config.MaxSourcePositions - 1 do
      begin
        RowArr := TJSONArray(PosArr.Items[PosCnt]);
        for ChCnt := 0 to Config.DModel - 1 do
        begin
          Diff := Abs(Enc.GetLastLayer().Output.FData[
            PosCnt * Config.DModel + ChCnt] - RowArr.Items[ChCnt].AsFloat);
          if Diff > MaxHiddenDiff then MaxHiddenDiff := Diff;
        end;
      end;
      // Full encoder-decoder parity through RunT5 (recomputes the encoder
      // and feeds its output into the decoder's second input).
      RunT5(Enc, Dec, EncInput, DecInput, Logits);
      AssertEquals('logits size', DecLen * Config.VocabSize, Logits.Size);
      PosArr := TJSONArray(LogitsArr.Items[SeqCnt]);
      for PosCnt := 0 to DecLen - 1 do
      begin
        RowArr := TJSONArray(PosArr.Items[PosCnt]);
        for ChCnt := 0 to Config.VocabSize - 1 do
        begin
          Diff := Abs(Logits.FData[PosCnt * Config.VocabSize + ChCnt] -
            RowArr.Items[ChCnt].AsFloat);
          if Diff > MaxLogitDiff then MaxLogitDiff := Diff;
        end;
      end;
    end;
    // f32 end-to-end vs the float64 oracle on f32-rounded weights. NEVER
    // loosen the gates past 1e-3 - fix the model, don't widen tolerance.
    AssertTrue('Whisper encoder hidden-state parity: max |diff| = ' +
      FloatToStr(MaxHiddenDiff) + ' must be < 1e-4', MaxHiddenDiff < 1e-4);
    AssertTrue('Whisper logit parity: max |diff| = ' +
      FloatToStr(MaxLogitDiff) + ' must be < 1e-4', MaxLogitDiff < 1e-4);
  finally
    RefRoot.Free;
    Logits.Free;
    DecInput.Free;
    EncInput.Free;
    RefJson.Free;
    Dec.Free;
    Enc.Free;
  end;
end;

