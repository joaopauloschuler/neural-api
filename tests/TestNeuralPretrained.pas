    AssertEquals('model_type', 'glm4', Config.ModelType);
    AssertEquals('layers', 2, Config.NumLayers);
    AssertEquals('heads', 2, Config.NumHeads);
    AssertEquals('kv_heads', 1, Config.NumKVHeads);
