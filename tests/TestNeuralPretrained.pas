procedure TTestNeuralPretrained.TestLlamaImporterFailsOnMissingTensor;
var
  Path: string;
  NN: TNNet;
  Config: TLlamaConfig;
  Failed: boolean;
  Payload: array of byte;
  i: integer;
begin
  RandSeed := 424242;
  // A "checkpoint" containing ONLY model.embed_tokens.weight [4, 4]: the
  // importer must fail loudly on the first missing block tensor, not
  // import partially.
  SetLength(Payload, 4 * 4 * 4);
  for i := 0 to High(Payload) do Payload[i] := 0;
  Path := WriteTempSafeTensors(
    '{"model.embed_tokens.weight":{"dtype":"F32","shape":[4,4],' +
    '"data_offsets":[0,64]}}', Payload);
  Config.HiddenSize := 4;
  Config.IntermediateSize := 6;
  Config.NumLayers := 1;
  Config.NumHeads := 2;
  Config.NumKVHeads := 1;
  Config.VocabSize := 4;
  Config.MaxPositions := 8;
  Config.RmsNormEps := 1e-6;
  Config.RopeTheta := 10000;
  Config.TieWordEmbeddings := true;
  Config.ModelType := 'llama';
  Config.SlidingWindow := 0;
  Config.QKVBias := false;
  Config.Prefix := '';
  Failed := false;
  NN := nil;
  try
    try
      NN := BuildLlamaFromSafeTensorsWithConfig(Path, Config);
    except
      on EPretrainedImportError do Failed := true;
    end;
  finally
    NN.Free;
    DeleteFile(Path);
  end;
  AssertTrue('missing block tensors must abort the import', Failed);
end;

// The flagship Llama test: imports the committed tiny random Llama-shaped
// checkpoint and asserts logit parity with the independent pure-Python
// oracle (tools/llama_tiny_fixture.py, verified to match HF transformers'
// LlamaForCausalLM to ~9e-7). Covers the rotate_half row permutation, GQA
// head sharing, per-token RMSNorm, SwiGLU mapping and the untied LM head.
procedure TTestNeuralPretrained.TestLlamaLogitParity;
var
  NN: TNNet;
  Config: TLlamaConfig;
  RefRoot: TJSONData;
  Sequences, SeqArr, LogitsArr, PosArr, RowArr: TJSONArray;
  Input, Output: TNNetVolume;
  RefJson: TStringList;
  SeqCnt, PosCnt, TokCnt: integer;
  Diff, MaxDiff: double;
  SeqLen, Vocab: integer;
begin
  RandSeed := 424242;
  NN := BuildLlamaFromSafeTensorsEx(FixturePath('tiny_llama.safetensors'),
    Config, {SeqLen=}0, {pInferenceOnly=}false,
    FixturePath('tiny_llama_config.json'));
  RefJson := TStringList.Create;
  Input := TNNetVolume.Create;
  Output := TNNetVolume.Create;
  RefRoot := nil;
  try
    AssertEquals('layers', 2, Config.NumLayers);
    AssertEquals('prefix', 'model.', Config.Prefix);
    SeqLen := Config.MaxPositions;
    Vocab := Config.VocabSize;
    RefJson.LoadFromFile(FixturePath('tiny_llama_logits.json'));
    RefRoot := GetJSON(RefJson.Text);
    Sequences := TJSONArray(TJSONObject(RefRoot).Find('sequences'));
    LogitsArr := TJSONArray(TJSONObject(RefRoot).Find('logits'));
    AssertTrue('sequences present', Sequences <> nil);
    AssertTrue('logits present', LogitsArr <> nil);
    AssertTrue('at least 3 sequences', Sequences.Count >= 3);
    MaxDiff := 0;
    Input.ReSize(SeqLen, 1, 1);
    for SeqCnt := 0 to Sequences.Count - 1 do
    begin
      SeqArr := TJSONArray(Sequences.Items[SeqCnt]);
      AssertEquals('sequence length', SeqLen, SeqArr.Count);
      for PosCnt := 0 to SeqLen - 1 do
        Input.FData[PosCnt] := SeqArr.Items[PosCnt].AsInteger;
      NN.Compute(Input);
      NN.GetOutput(Output);
      AssertEquals('output size', SeqLen * Vocab, Output.Size);
      PosArr := TJSONArray(LogitsArr.Items[SeqCnt]);
      for PosCnt := 0 to SeqLen - 1 do
      begin
        RowArr := TJSONArray(PosArr.Items[PosCnt]);
        for TokCnt := 0 to Vocab - 1 do
        begin
          Diff := Abs(Output.FData[PosCnt * Vocab + TokCnt] -
            RowArr.Items[TokCnt].AsFloat);
          if Diff > MaxDiff then MaxDiff := Diff;
        end;
      end;
    end;
    // f32 end-to-end vs the float64 Python oracle on f32-rounded weights.
    // NEVER loosen the gate past 1e-3 - if parity breaks, fix the model,
    // don't widen the tolerance.
    AssertTrue('Llama logit parity: max |diff| = ' +
      FloatToStr(MaxDiff) + ' must be < 1e-4', MaxDiff < 1e-4);
  finally
    RefRoot.Free;
    Output.Free;
    Input.Free;
    RefJson.Free;
    NN.Free;
  end;
end;

// Reader-level sharded-checkpoint coverage: tiny_llama.safetensors.index.json
// (generated by tools/shard_tiny_llama_fixture.py) splits the tiny Llama
// fixture into 2 shards. The sharded reader must expose exactly the same
// tensor set, dtypes, shapes and bytes as the single-file reader.
procedure TTestNeuralPretrained.TestShardedReaderMatchesSingleFile;
var
  Single1, Sharded: TNNetSafeTensorsReader;
  V1, V2: TNNetVolume;
  i, j: integer;
  TName: string;
begin
  RandSeed := 424242;
  Single1 := TNNetSafeTensorsReader.Create(
    FixturePath('tiny_llama.safetensors'));
  Sharded := TNNetSafeTensorsReader.Create(
    FixturePath('tiny_llama.safetensors.index.json'));
  V1 := TNNetVolume.Create;
  V2 := TNNetVolume.Create;
  try
    AssertEquals('single-file shard count', 1, Single1.ShardCount);
    AssertEquals('sharded shard count', 2, Sharded.ShardCount);
    AssertEquals('tensor count', Single1.Count, Sharded.Count);
    for i := 0 to Single1.Count - 1 do
    begin
      TName := Single1.TensorName(i);
      AssertTrue('sharded has ' + TName, Sharded.HasTensor(TName));
      AssertEquals('dtype of ' + TName, Single1.GetDType(TName),
        Sharded.GetDType(TName));
      AssertEquals('shape of ' + TName, Single1.ShapeAsString(TName),
        Sharded.ShapeAsString(TName));
      Single1.LoadTensorFlat(TName, V1);
      Sharded.LoadTensorFlat(TName, V2);
      AssertEquals('size of ' + TName, V1.Size, V2.Size);
      for j := 0 to V1.Size - 1 do
        if V1.FData[j] <> V2.FData[j] then
          Fail('tensor ' + TName + ' differs at element ' + IntToStr(j));
    end;
  finally
    V2.Free;
    V1.Free;
    Sharded.Free;
    Single1.Free;
  end;
end;

// End-to-end sharded import: BuildLlamaFromSafeTensorsEx pointed at the
// 2-shard index.json (NO importer changes - the reader handles sharding
// transparently) must produce logits BIT-IDENTICAL to the single-file load,
// and both must keep parity with the pinned Python oracle logits.
procedure TTestNeuralPretrained.TestShardedLlamaLogitsBitIdentical;
var
  NNSingle, NNSharded: TNNet;
  ConfigSingle, ConfigSharded: TLlamaConfig;
  Input, OutSingle, OutSharded: TNNetVolume;
  i: integer;
begin
  RandSeed := 424242;
  NNSingle := BuildLlamaFromSafeTensorsEx(
    FixturePath('tiny_llama.safetensors'), ConfigSingle, {SeqLen=}0,
    {pInferenceOnly=}false, FixturePath('tiny_llama_config.json'));
  NNSharded := BuildLlamaFromSafeTensorsEx(
    FixturePath('tiny_llama.safetensors.index.json'), ConfigSharded,
    {SeqLen=}0, {pInferenceOnly=}false,
    FixturePath('tiny_llama_config.json'));
  Input := TNNetVolume.Create(ConfigSingle.MaxPositions, 1, 1);
  OutSingle := TNNetVolume.Create;
  OutSharded := TNNetVolume.Create;
  try
    AssertEquals('layers', ConfigSingle.NumLayers, ConfigSharded.NumLayers);
    AssertEquals('prefix', 'model.', ConfigSharded.Prefix);
    for i := 0 to ConfigSingle.MaxPositions - 1 do
      Input.FData[i] := (i * 5 + 2) mod ConfigSingle.VocabSize;
    NNSingle.Compute(Input);
    NNSingle.GetOutput(OutSingle);
    NNSharded.Compute(Input);
    NNSharded.GetOutput(OutSharded);
    AssertEquals('output size', OutSingle.Size, OutSharded.Size);
    for i := 0 to OutSingle.Size - 1 do
      AssertEquals('sharded vs single-file logit ' + IntToStr(i),
        OutSingle.FData[i], OutSharded.FData[i], 0); // BIT-identical
    // The sharded import must also keep oracle parity on its own.
    AssertLogitParityWithFixture(NNSharded,
      FixturePath('tiny_llama_logits.json'), ConfigSharded.MaxPositions,
      ConfigSharded.VocabSize);
  finally
    OutSharded.Free;
    OutSingle.Free;
    Input.Free;
    NNSharded.Free;
    NNSingle.Free;
  end;
end;

