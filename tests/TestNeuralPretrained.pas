        for x := 0 to W - 1 do
          Img[x, yy, ch] :=
            TJSONArray(TJSONArray(PxArr.Items[ch]).Items[yy]).Items[x].AsFloat;
    // decoder token prefix padded with pad past the prefix (causal mask makes
