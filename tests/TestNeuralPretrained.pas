// Reader-level sharded torch.save coverage: tiny_gpt2.bin.index.json
// (generated by tools/shard_tiny_gpt2_bin_fixture.py) splits the tiny GPT-2
// .bin fixture into 2 torch.save shards behind the standard
// pytorch_model.bin.index.json weight_map. The sharded reader must expose
// exactly the same tensor set, dtypes, shapes and bytes as the single-file
// .bin reader.
procedure TTestNeuralPretrained.TestShardedTorchBinMatchesSingleFile;
var
  Single1, Sharded: TNNetTorchBinReader;
  V1, V2: TNNetVolume;
  i, j: integer;
  TName: string;
begin
  RandSeed := 424242;
  Single1 := TNNetTorchBinReader.Create(FixturePath('tiny_gpt2.bin'));
  Sharded := TNNetTorchBinReader.Create(
    FixturePath('tiny_gpt2.bin.index.json'));
  V1 := TNNetVolume.Create;
  V2 := TNNetVolume.Create;
  try
    AssertEquals('single-file shard count', 1, Single1.ShardCount);
    AssertEquals('sharded shard count', 2, Sharded.ShardCount);
    AssertEquals('tensor count', Single1.Count, Sharded.Count);
    for i := 0 to Single1.Count - 1 do
    begin
      TName := Single1.TensorName(i);
      AssertTrue('sharded has ' + TName, Sharded.HasTensor(TName));
      AssertEquals('dtype of ' + TName, Single1.GetDType(TName),
        Sharded.GetDType(TName));
      AssertEquals('shape of ' + TName, Single1.ShapeAsString(TName),
        Sharded.ShapeAsString(TName));
      Single1.LoadTensorFlat(TName, V1);
      Sharded.LoadTensorFlat(TName, V2);
      AssertEquals('size of ' + TName, V1.Size, V2.Size);
      for j := 0 to V1.Size - 1 do
        if V1.FData[j] <> V2.FData[j] then
          Fail('tensor ' + TName + ' differs at element ' + IntToStr(j));
    end;
  finally
    V2.Free;
    V1.Free;
    Sharded.Free;
    Single1.Free;
  end;
end;

// The sharded-bin index error taxonomy: a weight_map entry naming a tensor
// no shard contains, and a weight_map referencing a shard file that does
// not exist, must both raise a DESCRIPTIVE ETorchBinError (never a silent
// partial load).
procedure TTestNeuralPretrained.TestShardedTorchBinIndexErrors;
var
  Reader: TNNetTorchBinReader;
  TempDir, IndexPath, Msg: string;
  IndexText: TStringList;
  Failed: boolean;
begin
  RandSeed := 424242;
  TempDir := IncludeTrailingPathDelimiter(GetTempDir(false)) +
    'cai_bin_index_' + IntToStr(Random(1000000)) + DirectorySeparator;
  ForceDirectories(TempDir);
  IndexPath := TempDir + 'pytorch_model.bin.index.json';
  IndexText := TStringList.Create;
  try
    // ---- a mapped tensor missing from its shard's state_dict ----
    CopyFileTo(FixturePath('tiny_gpt2-00001-of-00002.bin'),
      TempDir + 'shard1.bin');
    IndexText.Text := '{"metadata": {}, "weight_map": {' +
      '"wte.weight": "shard1.bin", "no.such.tensor": "shard1.bin"}}';
    IndexText.SaveToFile(IndexPath);
    Failed := false;
    Msg := '';
    try
      Reader := TNNetTorchBinReader.Create(IndexPath);
      Reader.Free;
    except
      on E: ETorchBinError do
      begin
        Failed := true;
        Msg := E.Message;
      end;
    end;
    AssertTrue('weight_map tensor absent from every shard must raise ' +
      'ETorchBinError', Failed);
    AssertTrue('the error must name the missing tensor, got: ' + Msg,
      Pos('no.such.tensor', Msg) > 0);
    // ---- a referenced shard file that does not exist ----
    IndexText.Text := '{"metadata": {}, "weight_map": {' +
      '"wte.weight": "no_such_shard.bin"}}';
    IndexText.SaveToFile(IndexPath);
    Failed := false;
    Msg := '';
    try
      Reader := TNNetTorchBinReader.Create(IndexPath);
      Reader.Free;
    except
      on E: ETorchBinError do
      begin
        Failed := true;
        Msg := E.Message;
      end;
    end;
    AssertTrue('missing shard file must raise ETorchBinError', Failed);
    AssertTrue('the error must name the missing shard, got: ' + Msg,
      Pos('no_such_shard.bin', Msg) > 0);
  finally
    IndexText.Free;
    DeleteFile(IndexPath);
    DeleteFile(TempDir + 'shard1.bin');
    RemoveDir(TempDir);
  end;
end;

