      FixturePath('tiny_roberta_seqcls.safetensors'),
      0, false, FixturePath('tiny_roberta_seqcls_config.json'));
    try
      AssertEquals('roberta seqcls output depth', 3,
        NN.GetLastLayer().Output.Depth);
