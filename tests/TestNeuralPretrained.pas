      AssertEquals('id2label[0]', 'neg', Id2Label[0]);
      AssertEquals('id2label[2]', 'pos', Id2Label[2]);
      AssertEquals('num_labels output depth', 3,
        NN.GetLastLayer().Output.Depth);
