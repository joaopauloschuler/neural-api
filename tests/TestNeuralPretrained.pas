  ConfigJson: TStringList;
  Failed: boolean;
begin
  RandSeed := 424242;
  ConfigPath := IncludeTrailingPathDelimiter(GetTempDir(false)) +
    'cai_bfp_madeup_config_' + IntToStr(Random(1000000)) + '.json';
  ConfigJson := TStringList.Create;
