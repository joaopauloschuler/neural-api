    NN.Compute(ImageInput);
    MaxDiff := 0;
    for TokCnt := 0 to NumTokens - 1 do
    begin
      TokRow := TJSONArray(HiddenArr.Items[TokCnt]);
      for ColCnt := 0 to Config.HiddenSize - 1 do
