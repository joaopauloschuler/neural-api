    AssertEquals('round-trip layers', Config.NumLayers, ConfigG.NumLayers);
    AssertEquals('round-trip kv_heads', Config.NumKVHeads, ConfigG.NumKVHeads);
    AssertEquals('round-trip vocab', Config.VocabSize, ConfigG.VocabSize);
