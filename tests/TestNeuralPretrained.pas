    AssertEquals('one SwiGLU per expert per block',
      Config.NumLocalExperts * Config.NumLayers, SwiGLUCnt);
    AssertLogitParityWithFixture(NN,
      FixturePath('tiny_mixtral_logits.json'), Config.MaxPositions,
      Config.VocabSize);
