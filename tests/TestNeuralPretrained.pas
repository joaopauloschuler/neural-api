    AssertTrue('Llama safetensors round-trip: max |diff| = ' +
      FloatToStr(MaxDiff) + ' must be < 1e-5', MaxDiff < 1e-5);
  finally
    if FileExists(TmpPath) then DeleteFile(TmpPath);
    Out2.Free;
    Out1.Free;
