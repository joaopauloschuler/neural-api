// Per-token RMSNorm (TNNetTokenRMSNorm) must match a hand-computed HF
// LlamaRMSNorm: per (x,y) token over Depth, no mean subtraction, learnable
// gain, no bias; and survive a save/load round-trip.
procedure TTestNeuralPretrained.TestTokenRMSNormForwardAndSaveLoad;
var
  NN, NN2: TNNet;
  RMSLayer: TNNetLayer;
  Input, Out1, Out2: TNNetVolume;
  i, t, c: integer;
  MeanSqr, Expected: double;
  TokenVals: array[0..3] of double;
begin
  RandSeed := 424242;
  // (SeqLen=3, 1, Depth=4) input; per-token normalization over Depth.
  NN := TNNet.Create();
  NN.AddLayer( TNNetInput.Create(3, 1, 4) );
  RMSLayer := NN.AddLayer( TNNetTokenRMSNorm.Create(1e-5) );
  for c := 0 to 3 do
    RMSLayer.Neurons[0].Weights.FData[c] := 0.5 + 0.25 * c; // gain
  RMSLayer.FlushWeightCache();
  Input := TNNetVolume.Create(3, 1, 4);
  Out1 := TNNetVolume.Create;
  Out2 := TNNetVolume.Create;
  NN2 := TNNet.Create();
  try
    for i := 0 to Input.Size - 1 do
      Input.FData[i] := Sin(i * 1.7) * 2 + 0.3 * i;
    NN.Compute(Input);
    NN.GetOutput(Out1);
    // Hand-computed per-token RMSNorm for each of the 3 tokens.
    for t := 0 to 2 do
    begin
      MeanSqr := 0;
      for c := 0 to 3 do
      begin
        TokenVals[c] := Input.FData[t * 4 + c];
        MeanSqr := MeanSqr + Sqr(TokenVals[c]);
      end;
      MeanSqr := MeanSqr / 4;
      for c := 0 to 3 do
      begin
        Expected := (0.5 + 0.25 * c) *
          (TokenVals[c] / Sqrt(MeanSqr + 1e-5));
        AssertEquals('per-token RMSNorm value t=' + IntToStr(t) + ' c=' +
          IntToStr(c), Expected, Out1.FData[t * 4 + c], 1e-5);
      end;
    end;
    // Save/load round-trip must preserve structure, eps and gains.
    NN2.LoadFromString(NN.SaveToString());
    AssertTrue('reloaded layer class',
      NN2.Layers[1] is TNNetTokenRMSNorm);
    NN2.Compute(Input);
    NN2.GetOutput(Out2);
    for i := 0 to Out1.Size - 1 do
      AssertEquals('save/load forward equality at ' + IntToStr(i),
        Out1.FData[i], Out2.FData[i], 1e-7);
  finally
    NN2.Free;
    Out2.Free;
    Out1.Free;
    Input.Free;
    NN.Free;
  end;
end;

// The Llama importer compensates for HF's rotate_half pair layout
// (pairs (i, i+hd/2)) by permuting q/k projection rows into
// TNNetRotaryEmbedding's interleaved (2k, 2k+1) layout:
//   CAI channel 2k <- HF row k;  CAI channel 2k+1 <- HF row k+hd/2.
// This test feeds a PERMUTED head vector through TNNetRotaryEmbedding and
// asserts the result equals the hand-computed HF rotate_half rotation of
// the ORIGINAL vector, re-read through the same permutation.
procedure TTestNeuralPretrained.TestRotaryHalfPermutationMatchesHFRotateHalf;
const
  SeqLen = 5;
  HeadDim = 6; // half = 3
  RopeBase = 10000.0;
var
  NN: TNNet;
  Input, Output: TNNetVolume;
  HFVec, HFRot: array[0..HeadDim - 1] of double;
  Freq, CosV, SinV: double;
  Pos, i, Half: integer;
begin
  RandSeed := 424242;
  Half := HeadDim div 2;
  NN := TNNet.Create();
  NN.AddLayer( TNNetInput.Create(SeqLen, 1, HeadDim) );
  NN.AddLayer( TNNetRotaryEmbedding.Create(RopeBase) );
  Input := TNNetVolume.Create(SeqLen, 1, HeadDim);
  Output := TNNetVolume.Create;
  try
    for i := 0 to Input.Size - 1 do
      Input.FData[i] := Cos(i * 0.9) + 0.1 * i;
    NN.Compute(Input);
    NN.GetOutput(Output);
    for Pos := 0 to SeqLen - 1 do
    begin
      // Re-read the CAI channels back into the HF half-split layout:
      // HF row k = CAI channel 2k; HF row k+half = CAI channel 2k+1.
      for i := 0 to Half - 1 do
      begin
        HFVec[i] := Input.FData[Pos * HeadDim + 2 * i];
        HFVec[i + Half] := Input.FData[Pos * HeadDim + 2 * i + 1];
      end;
      // Hand-computed HF rotate_half rotation:
      //   y[i]      = x[i]*cos - x[i+half]*sin
      //   y[i+half] = x[i+half]*cos + x[i]*sin,  angle = pos * base^(-2i/hd)
      for i := 0 to Half - 1 do
      begin
        Freq := Exp(-2.0 * i / HeadDim * Ln(RopeBase));
        CosV := Cos(Pos * Freq);
        SinV := Sin(Pos * Freq);
        HFRot[i] := HFVec[i] * CosV - HFVec[i + Half] * SinV;
        HFRot[i + Half] := HFVec[i + Half] * CosV + HFVec[i] * SinV;
      end;
      for i := 0 to Half - 1 do
      begin
        AssertEquals('rotate_half pos=' + IntToStr(Pos) + ' k=' + IntToStr(i),
          HFRot[i], Output.FData[Pos * HeadDim + 2 * i], 1e-5);
        AssertEquals('rotate_half pos=' + IntToStr(Pos) + ' k+half=' +
          IntToStr(i), HFRot[i + Half],
          Output.FData[Pos * HeadDim + 2 * i + 1], 1e-5);
      end;
    end;
  finally
    Output.Free;
    Input.Free;
    NN.Free;
  end;
end;

// TNNetSwiGLU computes FIRSTHALF * Swish(SECONDHALF); the Llama importer
// therefore loads up_proj into the first depth half and gate_proj into the
// second. This test checks the layer against hand-computed
// silu(gate) * up on a (SeqLen=2, 1, 2*I) tensor packed [up | gate].
procedure TTestNeuralPretrained.TestSwiGLUMatchesLlamaMLPGating;
const
  Inter = 3;
  SeqLen = 2;
var
  NN: TNNet;
  Input, Output: TNNetVolume;
  UpV, GateV, Expected: double;
  t, i: integer;
begin
  RandSeed := 424242;
  NN := TNNet.Create();
  NN.AddLayer( TNNetInput.Create(SeqLen, 1, 2 * Inter) );
  NN.AddLayer( TNNetSwiGLU.Create() );
  Input := TNNetVolume.Create(SeqLen, 1, 2 * Inter);
  Output := TNNetVolume.Create;
  try
    for i := 0 to Input.Size - 1 do
      Input.FData[i] := Sin(i * 1.3) * 1.5 - 0.2;
    NN.Compute(Input);
    NN.GetOutput(Output);
    AssertEquals('SwiGLU output size', SeqLen * Inter, Output.Size);
    for t := 0 to SeqLen - 1 do
      for i := 0 to Inter - 1 do
      begin
        UpV := Input.FData[t * 2 * Inter + i];              // first half
        GateV := Input.FData[t * 2 * Inter + Inter + i];    // second half
        Expected := UpV * (GateV / (1 + Exp(-GateV)));      // up * silu(gate)
        AssertEquals('SwiGLU t=' + IntToStr(t) + ' i=' + IntToStr(i),
          Expected, Output.FData[t * Inter + i], 1e-5);
      end;
  finally
    Output.Free;
    Input.Free;
    NN.Free;
  end;
end;

