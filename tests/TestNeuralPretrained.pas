// MakeInferenceOnly shrinks every neuron's Delta/BackInertia training
// volumes; the forward pass must be bit-for-bit unaffected, whether the
// shrink happens during construction (pInferenceOnly=True) or on an
// already-built net (TNNet.MakeInferenceOnly).
procedure TTestNeuralPretrained.TestMakeInferenceOnlyKeepsOutputs;
var
  NNTrain, NNInfer: TNNet;
  Config: TGPT2Config;
  Input, OutTrain, OutInfer: TNNetVolume;
  i: integer;
begin
  NNTrain := BuildGPT2FromSafeTensorsEx(FixturePath('tiny_gpt2.safetensors'),
    Config, {SeqLen=}0, {NumHeads=}2);
  NNInfer := BuildGPT2FromSafeTensorsEx(FixturePath('tiny_gpt2.safetensors'),
    Config, {SeqLen=}0, {NumHeads=}2, {pInferenceOnly=}true);
  Input := TNNetVolume.Create(Config.NCtx, 1, 1);
  OutTrain := TNNetVolume.Create;
  OutInfer := TNNetVolume.Create;
  try
    for i := 0 to Config.NCtx - 1 do
      Input.FData[i] := (i * 3 + 1) mod Config.VocabSize;
    NNTrain.Compute(Input);
    NNTrain.GetOutput(OutTrain);
    NNInfer.Compute(Input);
    NNInfer.GetOutput(OutInfer);
    AssertEquals('output size', OutTrain.Size, OutInfer.Size);
    for i := 0 to OutTrain.Size - 1 do
      AssertEquals('pInferenceOnly logit ' + IntToStr(i),
        OutTrain.FData[i], OutInfer.FData[i], 0);
    // Shrinking a finished net must not change its outputs either.
    NNTrain.MakeInferenceOnly();
    NNTrain.Compute(Input);
    NNTrain.GetOutput(OutInfer);
    for i := 0 to OutTrain.Size - 1 do
      AssertEquals('post-build MakeInferenceOnly logit ' + IntToStr(i),
        OutTrain.FData[i], OutInfer.FData[i], 0);
    AssertEquals('delta volume shrunk', 1,
      NNTrain.Layers[1].Neurons[0].Delta.Size);
    AssertEquals('inertia volume shrunk', 1,
      NNTrain.Layers[1].Neurons[0].BackInertia.Size);
  finally
    OutInfer.Free;
    OutTrain.Free;
    Input.Free;
    NNInfer.Free;
    NNTrain.Free;
  end;
end;

// Per-token RMSNorm (TNNetTokenRMSNorm) must match a hand-computed HF
// LlamaRMSNorm: per (x,y) token over Depth, no mean subtraction, learnable
// gain, no bias; and survive a save/load round-trip.
procedure TTestNeuralPretrained.TestTokenRMSNormForwardAndSaveLoad;
var
  NN, NN2: TNNet;
  RMSLayer: TNNetLayer;
  Input, Out1, Out2: TNNetVolume;
  i, t, c: integer;
  MeanSqr, Expected: double;
  TokenVals: array[0..3] of double;
begin
  RandSeed := 424242;
  // (SeqLen=3, 1, Depth=4) input; per-token normalization over Depth.
  NN := TNNet.Create();
  NN.AddLayer( TNNetInput.Create(3, 1, 4) );
  RMSLayer := NN.AddLayer( TNNetTokenRMSNorm.Create(1e-5) );
  for c := 0 to 3 do
    RMSLayer.Neurons[0].Weights.FData[c] := 0.5 + 0.25 * c; // gain
  RMSLayer.FlushWeightCache();
  Input := TNNetVolume.Create(3, 1, 4);
  Out1 := TNNetVolume.Create;
  Out2 := TNNetVolume.Create;
  NN2 := TNNet.Create();
  try
    for i := 0 to Input.Size - 1 do
      Input.FData[i] := Sin(i * 1.7) * 2 + 0.3 * i;
    NN.Compute(Input);
    NN.GetOutput(Out1);
    // Hand-computed per-token RMSNorm for each of the 3 tokens.
    for t := 0 to 2 do
    begin
      MeanSqr := 0;
      for c := 0 to 3 do
      begin
        TokenVals[c] := Input.FData[t * 4 + c];
        MeanSqr := MeanSqr + Sqr(TokenVals[c]);
      end;
      MeanSqr := MeanSqr / 4;
      for c := 0 to 3 do
      begin
        Expected := (0.5 + 0.25 * c) *
          (TokenVals[c] / Sqrt(MeanSqr + 1e-5));
        AssertEquals('per-token RMSNorm value t=' + IntToStr(t) + ' c=' +
          IntToStr(c), Expected, Out1.FData[t * 4 + c], 1e-5);
      end;
    end;
    // Save/load round-trip must preserve structure, eps and gains.
    NN2.LoadFromString(NN.SaveToString());
    AssertTrue('reloaded layer class',
      NN2.Layers[1] is TNNetTokenRMSNorm);
    NN2.Compute(Input);
    NN2.GetOutput(Out2);
    for i := 0 to Out1.Size - 1 do
      AssertEquals('save/load forward equality at ' + IntToStr(i),
        Out1.FData[i], Out2.FData[i], 1e-7);
  finally
    NN2.Free;
    Out2.Free;
    Out1.Free;
    Input.Free;
    NN.Free;
  end;
end;

// The Llama importer compensates for HF's rotate_half pair layout
// (pairs (i, i+hd/2)) by permuting q/k projection rows into
// TNNetRotaryEmbedding's interleaved (2k, 2k+1) layout:
//   CAI channel 2k <- HF row k;  CAI channel 2k+1 <- HF row k+hd/2.
// This test feeds a PERMUTED head vector through TNNetRotaryEmbedding and
// asserts the result equals the hand-computed HF rotate_half rotation of
// the ORIGINAL vector, re-read through the same permutation.
procedure TTestNeuralPretrained.TestRotaryHalfPermutationMatchesHFRotateHalf;
const
  SeqLen = 5;
  HeadDim = 6; // half = 3
  RopeBase = 10000.0;
var
  NN: TNNet;
  Input, Output: TNNetVolume;
  HFVec, HFRot: array[0..HeadDim - 1] of double;
  Freq, CosV, SinV: double;
  Pos, i, Half: integer;
begin
  RandSeed := 424242;
  Half := HeadDim div 2;
  NN := TNNet.Create();
  NN.AddLayer( TNNetInput.Create(SeqLen, 1, HeadDim) );
  NN.AddLayer( TNNetRotaryEmbedding.Create(RopeBase) );
  Input := TNNetVolume.Create(SeqLen, 1, HeadDim);
  Output := TNNetVolume.Create;
  try
    for i := 0 to Input.Size - 1 do
      Input.FData[i] := Cos(i * 0.9) + 0.1 * i;
    NN.Compute(Input);
    NN.GetOutput(Output);
    for Pos := 0 to SeqLen - 1 do
    begin
      // Re-read the CAI channels back into the HF half-split layout:
      // HF row k = CAI channel 2k; HF row k+half = CAI channel 2k+1.
      for i := 0 to Half - 1 do
      begin
        HFVec[i] := Input.FData[Pos * HeadDim + 2 * i];
        HFVec[i + Half] := Input.FData[Pos * HeadDim + 2 * i + 1];
      end;
      // Hand-computed HF rotate_half rotation:
      //   y[i]      = x[i]*cos - x[i+half]*sin
      //   y[i+half] = x[i+half]*cos + x[i]*sin,  angle = pos * base^(-2i/hd)
      for i := 0 to Half - 1 do
      begin
        Freq := Exp(-2.0 * i / HeadDim * Ln(RopeBase));
        CosV := Cos(Pos * Freq);
        SinV := Sin(Pos * Freq);
        HFRot[i] := HFVec[i] * CosV - HFVec[i + Half] * SinV;
        HFRot[i + Half] := HFVec[i + Half] * CosV + HFVec[i] * SinV;
      end;
      for i := 0 to Half - 1 do
      begin
        AssertEquals('rotate_half pos=' + IntToStr(Pos) + ' k=' + IntToStr(i),
          HFRot[i], Output.FData[Pos * HeadDim + 2 * i], 1e-5);
        AssertEquals('rotate_half pos=' + IntToStr(Pos) + ' k+half=' +
          IntToStr(i), HFRot[i + Half],
          Output.FData[Pos * HeadDim + 2 * i + 1], 1e-5);
      end;
    end;
  finally
    Output.Free;
    Input.Free;
    NN.Free;
  end;
end;

// TNNetSwiGLU computes FIRSTHALF * Swish(SECONDHALF); the Llama importer
// therefore loads up_proj into the first depth half and gate_proj into the
// second. This test checks the layer against hand-computed
// silu(gate) * up on a (SeqLen=2, 1, 2*I) tensor packed [up | gate].
procedure TTestNeuralPretrained.TestSwiGLUMatchesLlamaMLPGating;
const
  Inter = 3;
  SeqLen = 2;
var
  NN: TNNet;
  Input, Output: TNNetVolume;
  UpV, GateV, Expected: double;
  t, i: integer;
begin
  RandSeed := 424242;
  NN := TNNet.Create();
  NN.AddLayer( TNNetInput.Create(SeqLen, 1, 2 * Inter) );
  NN.AddLayer( TNNetSwiGLU.Create() );
  Input := TNNetVolume.Create(SeqLen, 1, 2 * Inter);
  Output := TNNetVolume.Create;
  try
    for i := 0 to Input.Size - 1 do
      Input.FData[i] := Sin(i * 1.3) * 1.5 - 0.2;
    NN.Compute(Input);
    NN.GetOutput(Output);
    AssertEquals('SwiGLU output size', SeqLen * Inter, Output.Size);
    for t := 0 to SeqLen - 1 do
      for i := 0 to Inter - 1 do
      begin
        UpV := Input.FData[t * 2 * Inter + i];              // first half
        GateV := Input.FData[t * 2 * Inter + Inter + i];    // second half
        Expected := UpV * (GateV / (1 + Exp(-GateV)));      // up * silu(gate)
        AssertEquals('SwiGLU t=' + IntToStr(t) + ' i=' + IntToStr(i),
          Expected, Output.FData[t * Inter + i], 1e-5);
      end;
  finally
    Output.Free;
    Input.Free;
    NN.Free;
  end;
end;

procedure TTestNeuralPretrained.TestLlamaConfigFromJSONFile;
var
  Config: TLlamaConfig;
begin
  RandSeed := 424242;
  Config := ReadLlamaConfigFromJSONFile(FixturePath('tiny_llama_config.json'));
  AssertEquals('hidden_size', 8, Config.HiddenSize);
  AssertEquals('intermediate_size', 12, Config.IntermediateSize);
  AssertEquals('num_hidden_layers', 2, Config.NumLayers);
  AssertEquals('num_attention_heads', 2, Config.NumHeads);
  AssertEquals('num_key_value_heads', 1, Config.NumKVHeads);
  AssertEquals('vocab_size', 11, Config.VocabSize);
  AssertEquals('max_position_embeddings', 16, Config.MaxPositions);
  AssertEquals('rms_norm_eps', 1e-5, Config.RmsNormEps, 1e-9);
  AssertEquals('rope_theta', 10000.0, Config.RopeTheta, 1e-3);
  AssertFalse('tie_word_embeddings', Config.TieWordEmbeddings);
end;

procedure TTestNeuralPretrained.TestLlamaImporterFailsOnMissingTensor;
var
  Path: string;
  NN: TNNet;
  Config: TLlamaConfig;
  Failed: boolean;
  Payload: array of byte;
  i: integer;
begin
  RandSeed := 424242;
  // A "checkpoint" containing ONLY model.embed_tokens.weight [4, 4]: the
  // importer must fail loudly on the first missing block tensor, not
  // import partially.
  SetLength(Payload, 4 * 4 * 4);
  for i := 0 to High(Payload) do Payload[i] := 0;
  Path := WriteTempSafeTensors(
    '{"model.embed_tokens.weight":{"dtype":"F32","shape":[4,4],' +
    '"data_offsets":[0,64]}}', Payload);
  Config.HiddenSize := 4;
  Config.IntermediateSize := 6;
  Config.NumLayers := 1;
  Config.NumHeads := 2;
  Config.NumKVHeads := 1;
  Config.VocabSize := 4;
  Config.MaxPositions := 8;
  Config.RmsNormEps := 1e-6;
  Config.RopeTheta := 10000;
  Config.TieWordEmbeddings := true;
  Config.ModelType := 'llama';
  Config.SlidingWindow := 0;
  Config.QKVBias := false;
  // Hand-filled record: EVERY field must be set explicitly (a local record
  // is stack garbage otherwise - this used to leave HeadDim/QKNorm/
  // GegluFFN/EmbedScale & friends uninitialized, the source of an
  // intermittent AV in this test).
  Config.HeadDim := 0;
  Config.QKNorm := false;
  Config.GegluFFN := false;
  Config.RMSNormAddOne := false;
  Config.EmbedScale := 1.0;
  Config.QueryPreAttnScalar := 0;
  Config.AttnLogitSoftCap := 0;
  Config.FinalLogitSoftCap := 0;
  Config.SandwichNorm := false;
  Config.AltSlidingWindow := false;
  Config.Prefix := '';
  Failed := false;
  NN := nil;
  try
    try
      NN := BuildLlamaFromSafeTensorsWithConfig(Path, Config);
    except
      on EPretrainedImportError do Failed := true;
    end;
  finally
    NN.Free;
    DeleteFile(Path);
  end;
  AssertTrue('missing block tensors must abort the import', Failed);
end;

// The flagship Llama test: imports the committed tiny random Llama-shaped
// checkpoint and asserts logit parity with the independent pure-Python
// oracle (tools/llama_tiny_fixture.py, verified to match HF transformers'
// LlamaForCausalLM to ~9e-7). Covers the rotate_half row permutation, GQA
// head sharing, per-token RMSNorm, SwiGLU mapping and the untied LM head.
procedure TTestNeuralPretrained.TestLlamaLogitParity;
var
  NN: TNNet;
  Config: TLlamaConfig;
  RefRoot: TJSONData;
  Sequences, SeqArr, LogitsArr, PosArr, RowArr: TJSONArray;
  Input, Output: TNNetVolume;
  RefJson: TStringList;
  SeqCnt, PosCnt, TokCnt: integer;
  Diff, MaxDiff: double;
  SeqLen, Vocab: integer;
begin
  RandSeed := 424242;
  NN := BuildLlamaFromSafeTensorsEx(FixturePath('tiny_llama.safetensors'),
    Config, {SeqLen=}0, {pInferenceOnly=}false,
    FixturePath('tiny_llama_config.json'));
  RefJson := TStringList.Create;
  Input := TNNetVolume.Create;
  Output := TNNetVolume.Create;
  RefRoot := nil;
  try
    AssertEquals('layers', 2, Config.NumLayers);
    AssertEquals('prefix', 'model.', Config.Prefix);
    SeqLen := Config.MaxPositions;
    Vocab := Config.VocabSize;
    RefJson.LoadFromFile(FixturePath('tiny_llama_logits.json'));
    RefRoot := GetJSON(RefJson.Text);
    Sequences := TJSONArray(TJSONObject(RefRoot).Find('sequences'));
    LogitsArr := TJSONArray(TJSONObject(RefRoot).Find('logits'));
    AssertTrue('sequences present', Sequences <> nil);
    AssertTrue('logits present', LogitsArr <> nil);
    AssertTrue('at least 3 sequences', Sequences.Count >= 3);
    MaxDiff := 0;
    Input.ReSize(SeqLen, 1, 1);
    for SeqCnt := 0 to Sequences.Count - 1 do
    begin
      SeqArr := TJSONArray(Sequences.Items[SeqCnt]);
      AssertEquals('sequence length', SeqLen, SeqArr.Count);
      for PosCnt := 0 to SeqLen - 1 do
        Input.FData[PosCnt] := SeqArr.Items[PosCnt].AsInteger;
      NN.Compute(Input);
      NN.GetOutput(Output);
      AssertEquals('output size', SeqLen * Vocab, Output.Size);
      PosArr := TJSONArray(LogitsArr.Items[SeqCnt]);
      for PosCnt := 0 to SeqLen - 1 do
      begin
        RowArr := TJSONArray(PosArr.Items[PosCnt]);
        for TokCnt := 0 to Vocab - 1 do
        begin
          Diff := Abs(Output.FData[PosCnt * Vocab + TokCnt] -
            RowArr.Items[TokCnt].AsFloat);
          if Diff > MaxDiff then MaxDiff := Diff;
        end;
      end;
    end;
    // f32 end-to-end vs the float64 Python oracle on f32-rounded weights.
    // NEVER loosen the gate past 1e-3 - if parity breaks, fix the model,
    // don't widen the tolerance.
    AssertTrue('Llama logit parity: max |diff| = ' +
      FloatToStr(MaxDiff) + ' must be < 1e-4', MaxDiff < 1e-4);
  finally
    RefRoot.Free;
    Output.Free;
    Input.Free;
    RefJson.Free;
    NN.Free;
  end;
end;

// Reader-level sharded-checkpoint coverage: tiny_llama.safetensors.index.json
// (generated by tools/shard_tiny_llama_fixture.py) splits the tiny Llama
// fixture into 2 shards. The sharded reader must expose exactly the same
// tensor set, dtypes, shapes and bytes as the single-file reader.
procedure TTestNeuralPretrained.TestShardedReaderMatchesSingleFile;
var
  Single1, Sharded: TNNetSafeTensorsReader;
  V1, V2: TNNetVolume;
  i, j: integer;
  TName: string;
begin
  RandSeed := 424242;
  Single1 := TNNetSafeTensorsReader.Create(
    FixturePath('tiny_llama.safetensors'));
  Sharded := TNNetSafeTensorsReader.Create(
    FixturePath('tiny_llama.safetensors.index.json'));
  V1 := TNNetVolume.Create;
  V2 := TNNetVolume.Create;
  try
    AssertEquals('single-file shard count', 1, Single1.ShardCount);
    AssertEquals('sharded shard count', 2, Sharded.ShardCount);
    AssertEquals('tensor count', Single1.Count, Sharded.Count);
    for i := 0 to Single1.Count - 1 do
    begin
      TName := Single1.TensorName(i);
      AssertTrue('sharded has ' + TName, Sharded.HasTensor(TName));
      AssertEquals('dtype of ' + TName, Single1.GetDType(TName),
        Sharded.GetDType(TName));
      AssertEquals('shape of ' + TName, Single1.ShapeAsString(TName),
        Sharded.ShapeAsString(TName));
      Single1.LoadTensorFlat(TName, V1);
      Sharded.LoadTensorFlat(TName, V2);
      AssertEquals('size of ' + TName, V1.Size, V2.Size);
      for j := 0 to V1.Size - 1 do
        if V1.FData[j] <> V2.FData[j] then
          Fail('tensor ' + TName + ' differs at element ' + IntToStr(j));
    end;
  finally
    V2.Free;
    V1.Free;
    Sharded.Free;
    Single1.Free;
  end;
end;

// End-to-end sharded import: BuildLlamaFromSafeTensorsEx pointed at the
// 2-shard index.json (NO importer changes - the reader handles sharding
// transparently) must produce logits BIT-IDENTICAL to the single-file load,
// and both must keep parity with the pinned Python oracle logits.
procedure TTestNeuralPretrained.TestShardedLlamaLogitsBitIdentical;
var
  NNSingle, NNSharded: TNNet;
  ConfigSingle, ConfigSharded: TLlamaConfig;
  Input, OutSingle, OutSharded: TNNetVolume;
  i: integer;
begin
  RandSeed := 424242;
  NNSingle := BuildLlamaFromSafeTensorsEx(
    FixturePath('tiny_llama.safetensors'), ConfigSingle, {SeqLen=}0,
    {pInferenceOnly=}false, FixturePath('tiny_llama_config.json'));
  NNSharded := BuildLlamaFromSafeTensorsEx(
    FixturePath('tiny_llama.safetensors.index.json'), ConfigSharded,
    {SeqLen=}0, {pInferenceOnly=}false,
    FixturePath('tiny_llama_config.json'));
  Input := TNNetVolume.Create(ConfigSingle.MaxPositions, 1, 1);
  OutSingle := TNNetVolume.Create;
  OutSharded := TNNetVolume.Create;
  try
    AssertEquals('layers', ConfigSingle.NumLayers, ConfigSharded.NumLayers);
    AssertEquals('prefix', 'model.', ConfigSharded.Prefix);
    for i := 0 to ConfigSingle.MaxPositions - 1 do
      Input.FData[i] := (i * 5 + 2) mod ConfigSingle.VocabSize;
    NNSingle.Compute(Input);
    NNSingle.GetOutput(OutSingle);
    NNSharded.Compute(Input);
    NNSharded.GetOutput(OutSharded);
    AssertEquals('output size', OutSingle.Size, OutSharded.Size);
    for i := 0 to OutSingle.Size - 1 do
      AssertEquals('sharded vs single-file logit ' + IntToStr(i),
        OutSingle.FData[i], OutSharded.FData[i], 0); // BIT-identical
    // The sharded import must also keep oracle parity on its own.
    AssertLogitParityWithFixture(NNSharded,
      FixturePath('tiny_llama_logits.json'), ConfigSharded.MaxPositions,
      ConfigSharded.VocabSize);
  finally
    OutSharded.Free;
    OutSingle.Free;
    Input.Free;
    NNSharded.Free;
    NNSingle.Free;
  end;
end;

