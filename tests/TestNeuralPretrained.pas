  NN := BuildGPT2FromSafeTensorsEx(
    FixturePath('tiny_cerebras_gpt.safetensors'), Config, {SeqLen=}0,
    {NumHeads=}2, {pInferenceOnly=}false, {pSeqClsHead=}false,
    {pExactGelu=}true);
