    procedure AssertInt8DriftSeq2Seq(const FamilyName: string;
      EncF, DecF, EncQ, DecQ: TNNet; EncSeqLen, DecSeqLen, VocabRange,
      MinQuantLayers: integer; MaxRelDrift: double);
