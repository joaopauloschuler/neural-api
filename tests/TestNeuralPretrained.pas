    for LayerCnt := 0 to NN.Layers.Count - 1 do
    begin
      if NN.Layers[LayerCnt].ClassType = TNNetTopKGate then Inc(GateCnt);
      if NN.Layers[LayerCnt].ClassType = TNNetPointwiseSoftMax then
