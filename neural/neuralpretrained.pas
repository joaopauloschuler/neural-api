// NumChannels) normalized RGB volume and outputs (1, 1, NumLabels) logits.
function BuildSwinFromSafeTensors(Reader: TNNetSafeTensorsReader;
  const Config: TSwinConfig; pInferenceOnly: boolean = false): TNNet; overload;

