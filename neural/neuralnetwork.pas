  Cnt: integer;
begin
  Result := 0;
  if FLinkedNeurons then exit;
  if FNeurons.Count > 0 then
  begin
    for Cnt := 0 to FNeurons.Count-1 do
    begin
      Result := Result + FNeurons[Cnt].Weights.Size;
    end;
