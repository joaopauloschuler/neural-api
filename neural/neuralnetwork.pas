                {$ENDIF}
            end; // (LocalLearningErrorDeriv <> 0.0)
            Inc(OutputRawPos);
          end;
        end;
      end;
    end;

  if (FCalculatePrevLayerError) then
  begin
    if not(FShouldInterleaveWeights) then
