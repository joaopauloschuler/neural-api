      'TNNetSwishLearnable' :       Result := TNNetSwishLearnable.Create(Ft[0]);
      'TNNetMishLearnable' :        Result := TNNetMishLearnable.Create(Ft[0]);
      'TNNetISRU' :                 Result := TNNetISRU.Create(Ft[0]);
