  StartTime := Now();
  FOutput.CopyNoChecks(FPrevLayer.FOutput);
  FLRN.CalculateLocalResponseFromDepth(FOutput, FStruct[0], 0.001 / 9.0, 0.75);
  FOutput.Divi(FLRN);
  FForwardTime := FForwardTime + (Now() - StartTime);
