function TNNetLayer.InitAdam(Beta1, Beta2, Epsilon: TNeuralFloat): TNNetLayer;
var
  LpBnd276: integer;
  Cnt: integer;
begin
  FBeta1 := Beta1;
  FBeta2 := Beta2;
  FEpsilon := Epsilon;
  FBeta1Decay := 1;
  FBeta2Decay := 1;

  // Inference-only layers skip Adam optimizer-state allocation (training only).
  if not (FInferenceOnly) then
  begin
    if (FNeurons.Count > 0) then
    begin
      LpBnd276 := FNeurons.Count-1;
      for Cnt := 0 to LpBnd276 do
      begin
        FNeurons[Cnt].InitAdam(Self);
      end;
      AfterWeightUpdate();
    end;
  end;
  Result := Self;
end;

function TNNetLayer.SetInferenceOnly(pInferenceOnly: boolean): TNNetLayer;
var
  MaxLayer: integer;
  Cnt: integer;
begin
  Result := Self;
  FInferenceOnly := pInferenceOnly;
  // Shrink any training buffers already allocated (e.g. a layer that sized its
  // weights in the constructor, before this was chained). When the layer is
  // attached later, the FInferenceOnly flag stops them being re-allocated.
  MaxLayer := FNeurons.Count - 1;
  for Cnt := 0 to MaxLayer do
  begin
    FNeurons[Cnt].SetInferenceOnly(pInferenceOnly);
  end;
end;

