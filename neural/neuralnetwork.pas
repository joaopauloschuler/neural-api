  /// neural network
  TNNet = class(TMObject)
    protected
      FLayers: TNNetLayerList;
      FLearningRate: TNeuralFloat;
      FForwardTime: double;
      FBackwardTime: double;
      //Layer with Max Delta. You can read after calling GetMaxAbsoluteDelta.
