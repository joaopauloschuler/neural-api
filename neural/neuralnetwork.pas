  FOutput.ReSize(pPrevLayer.FOutput.SizeX + FPaddingX*2, pPrevLayer.FOutput.SizeY + FPaddingY*2, pPrevLayer.FOutput.Depth);
  if (pPrevLayer.FOutputError.Size = pPrevLayer.FOutput.Size) then
