  public
    procedure Compute(); override;
  end;

  /// Sinh activation function.
  // SinhAct(x) = sinh(x). Parameter-free. Derivative is cosh(x); cached into
  // FOutputErrorDeriv so TNNetReLUBase handles the backward chain rule with
