function TNNetNeuronList.GetMaxWeight(): TNeuralFloat;
var
  Cnt: integer;
  CountM1: integer;
  MaxValue: TNeuralFloat;
begin
  if Count > 0 then
  begin
    Result := Self[0].Weights.GetMax();
    if Count > 1 then
    begin
      CountM1 := Count - 1;
      for Cnt := 0 to CountM1 do
      begin
        MaxValue := Self[Cnt].Weights.GetMax();
        if MaxValue > Result then Result := MaxValue;
      end;
    end;
  end
  else
  begin
    Result := -1;
  end;
end;

