  NRelu := TNNetConvolutionReLU.Create(16,3,1,1);

  NN.AddLayer( TNNetInput.Create(32, 32, 16) );
  NN.AddLayer( NRelu );
  NN.DebugStructure();

  WriteLn('Test 3) CPU Output:');
  Input.FillForDebug();
