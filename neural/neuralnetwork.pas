function TNNetLayer.InitHeGaussianDepthwise(Value: TNeuralFloat): TNNetLayer;
var
  Cnt: integer;
begin
  if (FNeurons.Count > 0) then
  begin
    for Cnt := 0 to FNeurons.Count-1 do
