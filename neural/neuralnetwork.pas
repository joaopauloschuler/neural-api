  begin
    for Cnt := 0 to FNeurons.Count-1 do
    begin
      FNeurons[Cnt].Weights.ReSize(x,y,d);
      FNeurons[Cnt].BackInertia.ReSize(x,y,d);
      FNeurons[Cnt].Delta.ReSize(x,y,d);
