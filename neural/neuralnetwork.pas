  if (FNeurons.Count > 0) then
  begin
    for Cnt := 0 to FNeurons.Count-1 do
    begin
      FNeurons[Cnt].InitUniform(Value);
    end;
    AfterWeightUpdate();
  end;
  Result := Self;
end;

