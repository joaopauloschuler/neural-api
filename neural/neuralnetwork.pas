      vmovups ymm6, [edx]

      vmovups ymm3, [eax+32]
      vmovups ymm7, [edx+32]

      {$IFDEF AVX2}
      vfmadd231ps ymm0, ymm2, ymm6
      vfmadd231ps ymm1, ymm3, ymm7
      {$ELSE}
