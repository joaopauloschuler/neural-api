      // Pure CPU, single forward pass per sample, no training-time changes,
      // no new layer types.
      class function TopLogitMarginReport(
        NN: TNNet;
        Samples: TNNetVolumePairList;
        NumClasses: integer;
        HardExamplesPerClass: integer = 5
