  // TNNetCos and TNNetHyperbolicTangent. Note: grows exponentially, so it is
  // only appropriate for layers whose inputs are bounded.
  TNNetSinhAct = class(TNNetReLUBase)
  public
    procedure Compute(); override;
  end;

