procedure TNNetNeuron.InitLeCunUniform(Value: TNeuralFloat = 1);
var
  MulAux: Single;
begin
  InitUniform();
  MulAux := Value*Sqrt(2/(FWeights.Size));
  FWeights.Mul(MulAux);
end;

procedure TNNetNeuron.InitHeUniform(Value: TNeuralFloat = 1);
